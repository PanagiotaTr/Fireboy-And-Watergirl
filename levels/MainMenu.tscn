[node name="TitleLabel2" type="Label" parent="CanvasLayer/InfoPanel" unique_id=2093635390]
layout_mode = 1
anchors_preset = -1
anchor_left = -5.9
anchor_top = 14.375
anchor_right = 7.55
anchor_bottom = 22.35
offset_left = -36.0
offset_top = -10.0
offset_right = 16.0
offset_bottom = 16.0
theme_override_colors/font_color = Color(0.9490196, 0.7882353, 0.29803923, 1)
theme_override_constants/outline_size = 7
theme_override_font_sizes/font_size = 18
text = "For many years, mysterious earthquakes struck the Fire and 
Water Kingdoms. The tremors always seemed to come from the 
forbidden forest, where the ancient temples stood, and everyone 
believed the temples were cursed because no adventurer ever 
returned from them.

Now, together with Fireboy and Watergirl, you must begin a 
dangerous journey to uncover the truth. Along the way, you 
will explore ancient temples filled with traps, mechanisms, 
and locked gates. To reach the final level, you must first complete 
all the previous levels and overcome every challenge standing in 
your way. At the end of your journey, you will finally face the truth..."
horizontal_alignment = 1
metadata/_edit_use_anchors_ = true

